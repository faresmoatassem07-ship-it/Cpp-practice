#include <iostream>
#include <cmath>
#include <string>
#include <stack>
#include <queue>
using namespace std;

void ReverseQueue(queue<int>&q){
    stack<int>s;
    while(!q.empty()){ // loop until q has no elements left
        s.push(q.front()); // move elemnts to stack
        q.pop();
    }
    while(!s.empty()){ // loop until s is empty
        q.push(s.top()); //move elemts back to queue (order now reversed)
        s.pop();
    }
}

void PrintQueue(queue<int>q){
    while(!q.empty()){
        cout << q.front() <<endl;
        q.pop();
    }
}

int main(){
    
    queue<int>q;
    q.push(5);
    q.push(3);
    q.push(7);
    q.push(10);
    q.push(2);
    q.push(8);
    q.push(1);
    
    ReverseQueue(q);
    PrintQueue(q);

    return 0;
}




