#include <iostream>
#include <cmath>
#include <string>
#include <stack>
using namespace std;

void RemoveAll(stack<int>&s , int value){
    stack<int>temp;
    while(!s.empty()){
        temp.push(s.top());
        s.pop();
    }
    while(!temp.empty()){
        if(temp.top()==value){
            temp.pop();
        }
        else{
            s.push(temp.top());
            temp.pop();
        }
    }
}

void printStack(stack<int>s){
    while(!s.empty()){
        cout << s.top() <<endl;
        s.pop();
    }
}

int main() {
    stack<int>s;
    
    s.push(1);
    s.push(2);
    s.push(2);
    s.push(4);
    s.push(6);
    
    RemoveAll(s,2);
    printStack(s);
    
    return 0;
}
