#include <iostream>
#include <cmath>
#include <string>
#include <stack>
#include <queue>
using namespace std;

queue<int> RepeatElements(queue<int>q,int value ){ //value is for how many times u want each element to be repeated
    queue<int>temp;
    while(!q.empty()){
        for(int i =1 ; i<=value ; i++){
            temp.push(q.front());
        }
        q.pop();
    }
    return temp;
}

void PrintQueue(queue<int>q){
    int FixedSize = q.size();
    for(int i =0 ; i<FixedSize ; i++){
        cout << "| " <<q.front() << " |" ;
        q.pop();
    }
}

int main(){
    queue<int>q;
    
    q.push(1);
    q.push(4);
    q.push(6);
    q.push(9);
    
    queue<int>result = RepeatElements(q,3);
    PrintQueue(result);
    
    return 0;
}
