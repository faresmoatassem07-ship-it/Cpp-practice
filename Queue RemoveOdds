#include <queue>
using namespace std;


void RemoveOdds(queue<int>&q){ //using for loop
    int FixedSize = q.size();
    for(int i = 0 ; i<FixedSize ; i++){
        if(q.front()%2 ==0){
            q.push(q.front());
            q.pop();
        }
        else{
            q.pop();
        }
        
    }
}

queue<int> RemoveOdd(queue<int>q){ //using temp queue
    queue<int>temp;
    while(!q.empty()){
        if(q.front()%2==0){
            temp.push(q.front());
            q.pop();
        }
        else{
            q.pop();
        }
    }
    return temp;
}

void PrintQueue(queue<int>q){
    int FixedSize=q.size();
    for(int i=0 ; i<FixedSize ; i++){
        cout << "| " << q.front() << " |" ;
        q.pop();
    }
}

int main() { 
 queue<int>q;
     q.push(3);
