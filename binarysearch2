#include <iostream>
#include <cmath>
#include <string>
using namespace std;

int BinarySearch(int arr[],int size , int key){
    int LowerB=0;
    int HighB=size-1;
   
    
    while (LowerB<=HighB){
        int Midpoint = (LowerB+HighB)/2;
        if (arr[Midpoint]==key){
            return Midpoint;
        }
        else if (arr[Midpoint]>key){
            HighB=Midpoint-1;
        }
        else {
            LowerB=Midpoint+1;
        }
    }
    return -1;
}

int FirstOccurence(int arr[],int size , int key){
    int LowerB=0;
    int HighB=size-1;
    int result=-1
    while(LowerB<=HighB){
        Midpoint=(LowerB+HighB)/2;
        if (arr[Midpoint]==key){
            result = Midpoint;
            HighB=Midpoint-1;
        }
         else if (arr[Midpoint]>key){
            HighB=Midpoint-1;
        }
        else {
            LowerB=Midpoint+1;
        }
    }
    return result;

int main() {
