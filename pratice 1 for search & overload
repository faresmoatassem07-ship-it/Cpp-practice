    int BinarySearchAdvanced(int id){
        int LowerB=0;
        int UpperB = itemcount -1 ;
        int CountComparisions=0;
        
        while (LowerB<=UpperB){
            int Midpoint = (LowerB+UpperB)/2;
            if(arr[Midpoint] == id){
                return Midpoint;
                CountComparisions++; // total number of comparisions made for midpoint 
            }
            else if(arr[Midpoint].getID() > id){
                UpperB=Midpoint-1; //shift left
                cout <<"Now shifting Left " <<endl;
            }
            else if (arr[Midpoint] < id){
                LowerB = Midpoint+1; //shift right 
                cout << "Now shifting Right " <<endl;
            }
        }
        cout << "total Number of comparisions: " << CountComparisions <<endl;
        return -1 ; // element not found 
        
    }
    
    
