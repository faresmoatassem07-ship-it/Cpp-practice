#include <iostream>
#include <string>
#include <cmath>
#include <stack>
using namespace std;

void ReplaceAvalue(stack<int>&s,int old_value , int new_value){
    stack<int>temp;
    while(!s.empty()){
        if(s.top()==old_value){
            s.top()=new_value;
        }
        temp.push(s.top());
        s.pop();
    }
    while(!temp.empty()){
        s.push(temp.top());
        temp.pop();
    }
}

void printStack(stack<int>s){
    while(!s.empty()){
        cout << s.top() << endl;
        s.pop();
    }
}

int main() {
  stack<int>s;
  
  s.push(5);
  s.push(1);
  s.push(3);
  s.push(5);
  s.push(7);
  s.push(4);
  s.push(9);
  s.push(10);
  
  
  ReplaceAvalue(s,5,10);
  printStack(s);
  
  
  return 0;
}
