#include <iostream>
#include <cmath>
#include <string>
#include <stack>
#include <queue>
using namespace std;


void ShiftZeros(queue<int>&q){
    queue<int>temp;
    int FixedSize=q.size();
    for(int j=0 ; j<FixedSize ; j++){
        if(q.front()==0){
            temp.push(q.front());
        }
        else{
            q.push(q.front());
        }
        q.pop();
    }
    
    while(!temp.empty()){
        q.push(temp.front());
        temp.pop();
    }
}

void PrintQueue(queue<int>q){
    int FixedSize=q.size();
    for(int i=0 ; i<FixedSize ; i++){
        cout << "| " << q.front() << " |" ;
        q.pop();
    }
}

int main() { 
 queue<int>q;
     q.push(5);
     q.push(0);
     q.push(3);
     q.push(0);
     q.push(7);
     q.push(1);
    
    ShiftZeros(q);
    PrintQueue(q);
    
    
    return 0;
}
