#include <iostream>
#include <cmath>
#include <string>
#include <stack>
using namespace std;

void MoveBottomTop(stack<int>&s){
    stack<int>temp;
    int originalsize = s.size();
    int value ;
    if (s.empty() || s.size() == 1) { return; }
    for(int i =0 ; i<originalsize-1 ; i++){ //size -1 to loop over all stack until it reach last element(so if size = 5 then it will loop 4 times till last elem)
        temp.push(s.top());
        s.pop(); 
    }
    value = s.top(); //store the last element before popping
    s.pop();
    while(!temp.empty()){
        s.push(temp.top()); //retrive rest of elements in s
        temp.pop();
    }
    s.push(value); //finally push back our value(bottom elem now at top)
}

void PrintStack(stack<int>s){
    while(!s.empty()){
        cout << s.top() <<endl;
        s.pop();
    }
}

int main() {
   
   stack<int>s;
   
   s.push(9);
   s.push(2);
   s.push(3);
   s.push(4);
   s.push(5);
   s.push(7);
   
   MoveBottomTop(s);
   PrintStack(s);
   
   
    return 0;
}
