#include <iostream>
#include <cmath>
#include <string>
using namespace std;

int BinarySearch(int arr[] , int size , int key){
    int LowerB=0;
    int HighB=size-1;
    int ClosestIndex=0;
    
    while(LowerB<=HighB){
        int Midpoint=(LowerB+HighB)/2;
        if(arr[Midpoint]==key){ //checking if value at the our current midpoint index equals the key
            return Midpoint;
        }
        else if(arr[Midpoint]>key){ //eliminate the right side and midpoint included (shift left)
            HighB=Midpoint-1;
        } 
        else{
            LowerB=Midpoint+1; //elimate left side to make array smaller and shift right (keep looking right)
        }
        if(abs(arr[Midpoint]-key) < abs(arr[ClosestIndex]-key)){ // we here check if the difference between midpoint and our key is less each time or not to get the closest index to our key if not found
        ClosestIndex=Midpoint; //updating closestindex 
        }
    }
    return ClosestIndex ; //rather than returning -1 if not found we return the closest index to our key
    //If storing closest VALUE:ClosestValue = arr[midpoint]; 
    // meaning “Save the value at this midpoint.”
}
int main() {
    
    const int size = 7;
    int arr[]={10,20,30,40,50,60,70};
    
    cout << BinarySearch(arr,size,50)<<endl;
    cout << BinarySearch(arr,size,80)<<endl;
    
    
    return 0;
}
