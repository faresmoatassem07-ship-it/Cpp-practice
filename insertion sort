#include <iostream>
#include <cmath>
#include <string>

using namespace std;

void InsertionSort(int arr[] , int size){

    int CountS = 0; //count for each shift

    for(int i = 1 ; i < size ; i++){

        int key = arr[i];

        int j = i - 1;
        // here j is used to look at the elements
        // before i to place in correct position

        while (j >= 0 && arr[j] > key){
            // arr[j] > key used to check if elements
            // before current key are larger

            arr[j+1] = arr[j]; //shift right

            CountS++;

            j--; //keep moving left to check all elements
        }

        arr[j+1] = key; // insertion of our element

        cout << "Pass number " << i << ": " << endl;

        for (int z = 0 ; z < size ; z++){

            cout << arr[z] << " ";
        }
        cout <<endl;
    }
    
        cout << "the Count of total Shifts is: "
             << CountS << endl;
    
}

void printArray(int arr[] , int size){
    // final sorted updated array

    for (int x = 0 ; x < size ; x++){

        cout << arr[x] << endl;
    }
}

void FindMax(int arr[], int size){

    cout << "the Max value is: "
         << arr[size-1] << endl;
}

void FindMin(int arr[], int size){

    cout << "the Min value is: "
         << arr[0] << endl;
}

void CountEven(int arr[], int size){

    int count = 0;

    for (int k = 0 ; k < size ; k++){

        if (arr[k] % 2 == 0){

            count++;
        }
    }

    cout << "The number of Even numbers are: "
         << count << endl;
}

bool IsSorted(int arr[] , int size){

    for (int i = 0 ; i < size-1 ; i++){

        if (arr[i] > arr[i+1]){

            return false;
        }
    }
    return true;
}

int main() {

    const int size = 7;

    int Array[7] = {30,50,20,60,80,10,0};

    InsertionSort(Array , size);

    printArray(Array,size);

    FindMin(Array , size);

    FindMax(Array, size);

    IsSorted(Array, size);

    CountEven(Array , size);

    return 0;
}
